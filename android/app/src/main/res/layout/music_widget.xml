<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/music_widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Música"
        android:textColor="#111111"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/music_widget_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Radio"
        android:textColor="#992A3441"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/music_widget_track"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:maxLines="2"
        android:text="Workout Radio"
        android:textColor="#111111"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/music_widget_subtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:maxLines="2"
        android:text="Selecciona una emisora"
        android:textColor="#992A3441"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/music_widget_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:text="Pausado"
        android:textColor="#111111"
        android:textSize="13sp"
        android:textStyle="bold" />
</LinearLayout>